# --- API ---
NODE_ENV=development
PORT=3000

# Postgres (local docker-compose)
DATABASE_URL=postgresql://garments:garments@localhost:5432/garments_erp?schema=public

# Redis (local docker-compose)
REDIS_URL=redis://localhost:6379

# JWT secrets — generate strong values for non-dev (`openssl rand -hex 64`)
JWT_ACCESS_SECRET=replace-me-dev-only
JWT_REFRESH_SECRET=replace-me-dev-only
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:4200

# --- Web ---
NG_APP_API_BASE_URL=http://localhost:3000/api
